# Copy these into Coolify -> Environment Variables

# App runtime
APP_ENV=prod
MODE=stand-alone
UNIBEE_API_URL=https://unibeeapi.mebadigitalsolution.xyz
SERVER_ADDRESS=:8088
SERVER_JWT_KEY=replace-with-strong-random-key

# Database + Redis URL style (recommended for your setup)
MYSQL_URL=mysql://mysql:AayRZX62oXgTVmTzNJMyF47tfRp6lN4Rq2Gh14HnAJzpGDquVFcRbNXa69F9gDBP@gjh90y0omxsd0p5mgfhxupse:3306/default
REDIS_URL=redis://default:nJmwnr04k1LPX4NtIUC4WQmmZBtP97ysNW4p0c6n0XNREpNtcddWjKI060bipANh@gn38rbu6g7ac5lo4fhwgaxph:6379/0

# Database: choose ONE style
# Style A: full DSN link (preferred when available)
# DATABASE_LINK=mysql:unibee:password@tcp(mysql:3306)/unib?loc=UTC&parseTime=false

# Style B: split values
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=unib
DB_USER=unibee
DB_PASSWORD=replace-me
DB_QUERY=loc=UTC&parseTime=false

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=replace-me
# Optional
REDIS_DATABASE=0

# Optional Nacos
# NACOS_IP=
# NACOS_PORT=8848
# NACOS_NAMESPACE=
# NACOS_GROUP=
# NACOS_DATA_ID=

# Translation API keys (optional, required only if the translation endpoint is used)
