# Copy these into Coolify -> Environment Variables

# App runtime
APP_ENV=prod
MODE=stand-alone
UNIBEE_API_URL=https://billing.example.com
SERVER_ADDRESS=:8088
SERVER_JWT_KEY=replace-with-strong-random-secret

# Database: choose ONE style
# Style A: full DSN link (preferred when available)
# DATABASE_LINK=mysql:unibee:password@tcp(mysql:3306)/unib?loc=UTC&parseTime=false

# Style B: split values
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=unib
DB_USER=unibee
DB_PASSWORD=replace-me
DB_QUERY=loc=UTC&parseTime=false

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=replace-me
# Optional
REDIS_DATABASE=0

# Optional Nacos
# NACOS_IP=
# NACOS_PORT=8848
# NACOS_NAMESPACE=
# NACOS_GROUP=
# NACOS_DATA_ID=
